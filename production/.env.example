# ═══════════════════════════════════════════════════════════════
#  Production Path — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#

# ── Azure AI Foundry Endpoint ──
# Your project endpoint from the Microsoft Foundry portal.
# Format: https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_ENDPOINT=https://your-hub.services.ai.azure.com/api/projects/your-project

# ── Model Deployment Name ──
FOUNDRY_MODEL=gpt-5.4

# ── Playwright MCP Server URL ──
# The remote MCP endpoint deployed on Azure Container Apps.
# Set after running:  cd infra && bash deploy.sh
# Format: https://<app-name>.<unique-id>.<region>.azurecontainerapps.io/mcp
PLAYWRIGHT_MCP_URL=

# ── Persistent Agent Name (set by setup_agent.py) ──
# FOUNDRY_AGENT_NAME=

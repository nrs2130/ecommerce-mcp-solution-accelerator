# ═══════════════════════════════════════════════════════════════
#  E-Commerce MCP Solution Accelerator — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#

# ── Azure AI Foundry Endpoint ──
# Your project endpoint from the Azure AI Foundry portal.
# Format: https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_ENDPOINT=https://your-hub.services.ai.azure.com/api/projects/your-project

# ── Model Deployment Name ──
# The name of your GPT model deployment in Azure AI Foundry.
# Default: gpt-5.4  (change to match your deployment name)
FOUNDRY_MODEL=gpt-5.4
